{
	"schemaVersion": 1,
	"id": "advanced-timer",
	"version": "${version}",
	"name": "Advanced Timer",
	"description": "This is an example description! Tell everyone what your mod is about!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/advanced-timer/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			{
				"value": "de.lenox.client.AdvancedTimerClient",
				"adapter": "kotlin"
			}
		],
		"modmenu": [
			{
				"value": "de.lenox.client.ModMenuIntegration",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		{
			"config": "advanced-timer.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.6",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}